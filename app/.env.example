# ── Database ────────────────────────────────────────────────────────────────
# Neon connection strings. Get from https://console.neon.tech/ → Project →
# Connection Details. Pooled URL is the default; unpooled is used by
# drizzle-kit migrations and any long-lived script.
DATABASE_URL="postgres://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require"
DATABASE_URL_UNPOOLED="postgres://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# ── Auth.js ─────────────────────────────────────────────────────────────────
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=""
# Canonical app URL. Use http://localhost:3000 for local dev; the production
# URL on Vercel.
AUTH_URL="http://localhost:3000"

# ── Google OAuth (REQUIREMENTS §11) ─────────────────────────────────────────
# Create at https://console.cloud.google.com/ → APIs & Services →
# Credentials → OAuth 2.0 Client ID. Authorized redirect URIs must include
# {AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Email magic-link (REQUIREMENTS §11) ─────────────────────────────────────
# SMTP relay. Local dev: any inbox-catcher (Mailpit, MailHog, Mailcatcher).
# Production: provider chosen at Phase 8 (frontrunner: Resend SMTP).
EMAIL_SERVER="smtp://user:pass@smtp.example.com:587"
EMAIL_FROM="Wander <noreply@example.com>"

# ── Google Maps (Phase 4) ───────────────────────────────────────────────────
# Two keys — one server-only (Directions / Places API server-side), one
# client-side (Maps JS + Places Autocomplete). Same key value works if you
# restrict by HTTP referrer; separate keys with separate restrictions are
# safer at scale.
GOOGLE_MAPS_API_KEY=""
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# Map ID for cloud-styled vector maps. Get from Google Cloud Console →
# Maps → Map Management. Optional but recommended (vector > raster).
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=""

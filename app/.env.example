# ── Database ────────────────────────────────────────────────────────────────
# Neon connection strings. Get from https://console.neon.tech/ → Project →
# Connection Details. Pooled URL is the default; unpooled is used by
# drizzle-kit migrations and any long-lived script.
DATABASE_URL="postgres://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require"
DATABASE_URL_UNPOOLED="postgres://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# ── Auth.js ─────────────────────────────────────────────────────────────────
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=""
# Canonical app URL. Use http://localhost:3000 for local dev; the production
# URL on Vercel.
AUTH_URL="http://localhost:3000"

# ── Google OAuth (REQUIREMENTS §11) ─────────────────────────────────────────
# Create at https://console.cloud.google.com/ → APIs & Services →
# Credentials → OAuth 2.0 Client ID. Authorized redirect URIs must include
# {AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Email magic-link (REQUIREMENTS §11) ─────────────────────────────────────
# SMTP relay. Local dev: any inbox-catcher (Mailpit, MailHog, Mailcatcher).
# Production: provider chosen at Phase 8 (frontrunner: Resend SMTP).
EMAIL_SERVER="smtp://user:pass@smtp.example.com:587"
EMAIL_FROM="Wander <noreply@example.com>"

# ── Google Maps (Phase 4) ───────────────────────────────────────────────────
# Two keys with different restrictions:
#
#   GOOGLE_MAPS_API_KEY (server-only, NOT prefixed NEXT_PUBLIC_)
#     Used by `lib/routes-server.ts` to call the Routes REST API
#     (https://routes.googleapis.com/directions/v2:computeRoutes).
#     Restrict in Cloud Console: API allowlist = "Routes API" only.
#     IP-restrict to your server egress IPs (Vercel:
#     https://vercel.com/docs/edge-network/regions) or leave unrestricted
#     but keep API allowlist tight.
#
#   NEXT_PUBLIC_GOOGLE_MAPS_API_KEY (client-side, exposed in JS bundle)
#     Used by Maps JS API (map widget) + Places API (New) for autocomplete
#     and place details. Restrict by HTTP referrer = your domain(s).
#     API allowlist = "Maps JavaScript API" + "Places API (New)" only.
#
# Separate keys with separate restrictions are required at scale; sharing
# a value is acceptable only if both restriction sets are loose.
GOOGLE_MAPS_API_KEY=""
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# Map ID for cloud-styled vector maps. Get from Google Cloud Console →
# Maps → Map Management. Optional but recommended (vector > raster).
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=""

# ── Feature flags (lib/feature-flags.ts) ────────────────────────────────────
# Server-only. Read once at module load; restart server after change.
# Accepted truthy values: true, 1, yes, on (case-insensitive). Anything else
# (including unset/empty) = false.

# Routes API toggle. OFF → skip Routes REST calls; map renders dashed
# straight lines between pins. Use to halt billing during dev or when
# quota is exhausted.
# Default: ON.
ROUTES_API_ENABLED="true"

# Auth bypass. ON → skip Google OAuth; auto sign-in as a fixed dev user
# (id 00000000-0000-0000-0000-0000000d3000, email dev-bypass@local). Dev
# user row is upserted on first request.
# NEVER set ON in production — it returns a valid session for any caller.
# Default: OFF.
AUTH_BYPASS="false"
